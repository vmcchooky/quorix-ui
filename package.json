{
  "name": "@quorix/ui",
  "version": "2.1.1",
  "description": "Design System for Quorix Vietnam",
  "main": "dist/quorix.min.js",
  "module": "dist/quorix.esm.js",
  "style": "dist/quorix.min.css",
  "exports": {
    ".": {
      "import": "./dist/quorix.esm.js",
      "require": "./dist/quorix.min.js",
      "default": "./dist/quorix.min.js"
    },
    "./css": "./dist/quorix.min.css",
    "./css/colors": "./css/colors.css",
    "./css/components": "./css/components.css",
    "./css/animations": "./css/animations.css"
  },
  "files": [
    "dist",
    "css",
    "js",
    "fonts"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build:css": "esbuild css/index.css --bundle --minify --outfile=dist/quorix.min.css --loader:.woff2=file",
    "build:js:cjs": "esbuild js/quorix.ts --bundle --minify --platform=browser --outfile=dist/quorix.min.js",
    "build:js:esm": "esbuild js/quorix.ts --bundle --minify --platform=browser --format=esm --outfile=dist/quorix.esm.js",
    "build:js": "npm-run-all build:js:cjs build:js:esm",
    "build": "npm-run-all build:css build:js",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vmcchooky/quorix-ui.git"
  },
  "author": "Vo Manh Cuong",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.0"
  }
}